/*
 * Ethernet FMC port config: all 4 ports (ports-0123).
 *
 * Wires the external Ethernet FMC PHYs onto the PL AXI Ethernet cores. The
 * axi_ethernet_N nodes themselves come from the SDT's pl.dtsi (generated from
 * the XSA); this overlay adds the board knowledge the XSA does not carry: the
 * MAC address, PHY handle, MDIO bus and RGMII phy-mode for each active port.
 *
 * Selected per target by the bsp/port-configs/ports-0123 overlay layer.
 */

&axi_ethernet_0 {
	/delete-property/ xlnx,phy-type;
	local-mac-address = [00 0a 35 00 01 22];
	phy-handle = <&extphy0>;
	xlnx,has-mdio = <0x1>;
	phy-mode = "rgmii-rxid";
	mdio {
		#address-cells = <1>;
		#size-cells = <0>;
		extphy0: phy@0 {
			device_type = "ethernet-phy";
			reg = <0>;
		};
	};
};

&axi_ethernet_1 {
	/delete-property/ xlnx,phy-type;
	local-mac-address = [00 0a 35 00 01 23];
	phy-handle = <&extphy1>;
	xlnx,has-mdio = <0x1>;
	phy-mode = "rgmii-rxid";
	mdio {
		#address-cells = <1>;
		#size-cells = <0>;
		extphy1: phy@0 {
			device_type = "ethernet-phy";
			reg = <0>;
		};
	};
};

&axi_ethernet_2 {
	/delete-property/ xlnx,phy-type;
